# Encryption key for API keys stored in the database
# Generate using: openssl rand -base64 32
# IMPORTANT: Keep this key safe! If you lose it, you'll lose access to encrypted data.
SALT_KEY=

# URL of the AnkiConnect instance to use for the server-side proxy.
# Defaults to http://127.0.0.1:8765 (Anki running on the same machine as Redefine).
# Set this if Anki runs on a different host, e.g. ANKI_CONNECT_URL=http://192.168.1.10:8765
ANKI_CONNECT_URL=
