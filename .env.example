# Database Configuration
# These variables are required for PostgreSQL setup
DB_USER=redefine
DB_PASSWORD=redefine_password
DB_NAME=redefine

# Security Configuration
# IMPORTANT: Replace this with a secure random string (at least 16 characters)
# This key is used for encrypting and decrypting API keys stored in the database
# The same key must be used consistently or previously encrypted data will be inaccessible
SALT_KEY=replace_with_secure_random_string

# Application Environment
# Valid values: production, development
FLASK_ENV=production
